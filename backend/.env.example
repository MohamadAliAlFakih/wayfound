# Copy to .env and fill in real values. Never commit .env.

# === REQUIRED — backend will fail-fast at startup if any of these are missing ===
DATABASE_URL=postgresql+asyncpg://wayfound:wayfound@localhost:5432/wayfound
JWT_SECRET_KEY=change-me-to-a-32-char-or-longer-random-string-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# === OPTIONAL — backend falls back to None when absent ===
OPENAI_API_KEY=sk-...
GROQ_API_KEY=
DISCORD_WEBHOOK_URL=
LANGSMITH_API_KEY=
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
OPENWEATHER_API_KEY=
OPEN_EXCHANGE_RATES_APP_ID=
